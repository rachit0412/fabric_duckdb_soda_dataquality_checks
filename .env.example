# Data Quality Platform - Environment Configuration
# Copy this file to .env and fill in your values
# Used by docker-compose.yml and application settings

# ============================================================================
# CORE APPLICATION SETTINGS
# ============================================================================

APP_NAME=Data Quality Platform
APP_VERSION=1.0.0
APP_ENV=development
ENVIRONMENT=development

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_LOG_LEVEL=INFO

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Connection (Primary Storage)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-with-a-32-char-random-password
POSTGRES_DB=data_quality
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database Connection Pool
DB_POOL_SIZE=20
DB_POOL_RECYCLE=3600
DB_ECHO=False

# ============================================================================
# DUCKDB CONFIGURATION
# ============================================================================

# DuckDB Path (for CSV/Parquet processing)
DUCKDB_PATH=my_database.myduckdb
DUCKDB_TEMP_PATH=/tmp/duckdb
DUCKDB_MAX_THREADS=4

# ============================================================================
# SODA CORE CONFIGURATION
# ============================================================================

# Soda Paths and Configuration
SODA_CONFIG_PATH=/soda_duckdb/config.yml
SODA_CHECKS_PATH=/soda_duckdb/checks.yml
SODA_LOGGING_ENABLED=True
SODA_LOG_LEVEL=INFO
SODA_TEMP_PATH=/tmp/soda

# Soda Thresholds
SODA_WARN_THRESHOLD=10
SODA_FAIL_THRESHOLD=50

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# React App Configuration
REACT_APP_API_URL=http://localhost:8001/api/v1
REACT_APP_ENV=development
FRONTEND_PORT=3010

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# CORS Configuration
CORS_ORIGINS=http://localhost:3010,http://localhost:5173,http://127.0.0.1:3010,http://127.0.0.1:5173

# JWT/Auth (v1.1+)
JWT_SECRET=change-me-with-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Secret Key (for session encryption)
SECRET_KEY=change-me-with-a-long-random-session-secret

# pgAdmin (optional admin profile only)
PGADMIN_PASSWORD=change-me-before-enabling-pgadmin

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================

# File Upload Settings
UPLOAD_DIRECTORY=./data/uploads
LAKEHOUSE_PATH=/lakehouse/default/Files
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_EXTENSIONS=csv,parquet,xlsx,json

# Storage Backend
STORAGE_BACKEND=postgresql

# ============================================================================
# WORKER CONFIGURATION
# ============================================================================

# Background Job Processing
WORKER_ENABLED=True
WORKER_MAX_CONCURRENT_TASKS=10
WORKER_TIMEOUT_SECONDS=3600
WORKER_POLL_INTERVAL_MS=1000

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Prometheus Metrics
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# Sentry Error Tracking (optional)
SENTRY_ENABLED=False
SENTRY_DSN=https://your-sentry-url@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Feature Toggles (for v1.1+)
FEATURE_AUTH_ENABLED=False
FEATURE_MULTI_TENANCY_ENABLED=False
FEATURE_GREAT_EXPECTATIONS_ENABLED=False
FEATURE_COSMOS_DB_ENABLED=False

# ============================================================================
# EXTERNAL INTEGRATIONS (v1.1+)
# ============================================================================

# Cloud Storage (S3)
AWS_ENABLED=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=data-quality-platform
AWS_REGION=us-east-1

# BigQuery
BIGQUERY_ENABLED=False
BIGQUERY_PROJECT_ID=
BIGQUERY_CREDENTIALS_PATH=

# Snowflake
SNOWFLAKE_ENABLED=False
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=

# ============================================================================
# ALERTING CONFIGURATION
# ============================================================================
ALERTING_ENABLED=true

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Debug Mode
DEBUG=False

# Database Seed Data
SEED_SAMPLE_DATA=True

# Test Configuration
PYTEST_ENABLED=True
TEST_DATABASE_URL=postgresql://postgres:change-me-with-a-32-char-random-password@localhost:5432/test_data_quality

# ============================================================================
# DOCKER COMPOSE PORTS
# ============================================================================

API_PORT=8001
POSTGRES_PORT=5432
PGADMIN_PORT=5050

# ============================================================================
# NOTES
# ============================================================================

# For Production:
# 1. Generate strong SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. Use environment-specific .env files (.env.prod, .env.staging)
# 3. Never commit sensitive values to Git; create .env.local (ignored in .gitignore)
# 4. Use secrets management (AWS Secrets Manager, Azure Key Vault, HashiCorp Vault)
# 5. Enable JWT_AUTH=True and configure OAuth/SAML
# 6. Set DEBUG=False
# 7. Use strong POSTGRES_PASSWORD
# 8. Configure SENTRY for error tracking

# For Development:
# 1. Use defaults below for quick local setup
# 2. Create .env.local for personal overrides (ignored by .gitignore)
# 3. Run: docker compose up -d

# For Testing:
# 1. Create .env.test file with test-specific values
# 2. Run: pytest (will use .env.test)

EMAIL_ALERTS_ENABLED=true

# Email Configuration (SMTP)
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SENDER_EMAIL=data-quality-alerts@your-company.com
RECIPIENT_EMAILS=team@your-company.com,manager@your-company.com

# Microsoft Teams Webhook
# Get this from Teams > Channel > Connectors > Incoming Webhook
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-url

# =============================================================================
# QUALITY THRESHOLDS
# =============================================================================
# Minimum pass rate before triggering CRITICAL status (0.0 to 1.0)
CRITICAL_FAILURE_THRESHOLD=0.95

# Minimum pass rate before triggering WARNING status (0.0 to 1.0)
WARNING_THRESHOLD=0.98

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_ANOMALY_DETECTION=true
ENABLE_DATA_PROFILING=true
ENABLE_HISTORICAL_ANALYSIS=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/data_quality.log

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8001

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Maximum number of rows to profile (for performance)
MAX_PROFILE_ROWS=1000000

# Anomaly detection sensitivity
Z_SCORE_THRESHOLD=3.0
IQR_MULTIPLIER=1.5
