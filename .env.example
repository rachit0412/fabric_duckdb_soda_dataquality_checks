# Environment Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================
ENVIRONMENT=development  # Options: development, staging, production

# =============================================================================
# LAKEHOUSE AND DATABASE PATHS
# =============================================================================
LAKEHOUSE_PATH=/lakehouse/default/Files
DUCKDB_PATH=my_database.myduckdb
SODA_CONFIG_PATH=/lakehouse/default/Files/soda_duckdb/config.yml
SODA_CHECKS_PATH=/lakehouse/default/Files/soda_duckdb/checks.yml

# =============================================================================
# STORAGE BACKEND CONFIGURATION
# =============================================================================
# Options: postgresql, cosmosdb, none
STORAGE_BACKEND=postgresql

# =============================================================================
# POSTGRESQL CONFIGURATION (Default - Recommended)
# =============================================================================
# Free, open-source, and works anywhere
# Hosting options: Azure Database for PostgreSQL, AWS RDS, Docker, on-premise

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=data_quality
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_SSLMODE=prefer

# =============================================================================
# AZURE COSMOS DB CONFIGURATION (Optional Alternative)
# =============================================================================
# Get these values from Azure Portal > Cosmos DB Account > Keys
# Note: Cosmos DB has operational costs, PostgreSQL is free/cheaper

COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-primary-or-secondary-key-here
COSMOS_DB_NAME=data_quality
COSMOS_CONTAINER_NAME=scan_results

# =============================================================================
# ALERTING CONFIGURATION
# =============================================================================
ALERTING_ENABLED=true
EMAIL_ALERTS_ENABLED=true

# Email Configuration (SMTP)
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SENDER_EMAIL=data-quality-alerts@your-company.com
RECIPIENT_EMAILS=team@your-company.com,manager@your-company.com

# Microsoft Teams Webhook
# Get this from Teams > Channel > Connectors > Incoming Webhook
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-url

# =============================================================================
# QUALITY THRESHOLDS
# =============================================================================
# Minimum pass rate before triggering CRITICAL status (0.0 to 1.0)
CRITICAL_FAILURE_THRESHOLD=0.95

# Minimum pass rate before triggering WARNING status (0.0 to 1.0)
WARNING_THRESHOLD=0.98

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_ANOMALY_DETECTION=true
ENABLE_DATA_PROFILING=true
ENABLE_HISTORICAL_ANALYSIS=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/data_quality.log

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Maximum number of rows to profile (for performance)
MAX_PROFILE_ROWS=1000000

# Anomaly detection sensitivity
Z_SCORE_THRESHOLD=3.0
IQR_MULTIPLIER=1.5
