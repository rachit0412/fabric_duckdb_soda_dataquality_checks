# Data Quality Platform - Environment Configuration for MVP

# Application
DEBUG=false
APP_VERSION=1.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://dq_user:change-me-with-a-32-char-random-password@localhost:5432/dq_platform
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Worker
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_SECONDS=5
JOB_TIMEOUT_SECONDS=300
JOB_MAX_RETRIES=3

# Profiling
PROFILE_SAMPLE_SIZE=10000
PROFILE_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO

# Data Source Credentials (per environment)
# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-with-a-32-char-random-password

# BigQuery (optional for MVP)
# BIGQUERY_PROJECT_ID=my-project
# BIGQUERY_CREDENTIALS_PATH=/path/to/credentials.json

# Snowflake (optional for MVP)
# SNOWFLAKE_ACCOUNT=xy12345.us-east-1
# SNOWFLAKE_USER=user
# SNOWFLAKE_PASSWORD=password
