{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    
    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/components/CheckSelectionStep.tsx",
    "src/components/DataSourceStep.tsx",
    "src/components/ParametersConfigStep.tsx",
    "src/components/WizardStepper.tsx",
    "src/components/ConnectDataset.tsx",
    "src/components/ReviewExecuteStep.tsx",
    "src/components/ResultsView.tsx",
    "src/components/ResultsVisualization.tsx",
    "src/store/store.ts",
    "src/hooks",
    "src/utils"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
